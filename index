        function showCustomDialog(type, title, message, onConfirm = null, onCancel = null) {
            const overlay = document.getElementById("custom-dialog-overlay");
            if (!overlay) return;
            const iconEl = document.getElementById("dialog-icon");
            const titleEl = document.getElementById("dialog-title");
            const messageEl = document.getElementById("dialog-message");
            const btnConfirm = document.getElementById("dialog-btn-confirm");
            const btnCancel = document.getElementById("dialog-btn-cancel");

            if (iconEl) {
                iconEl.className = "w-11 h-11 rounded-full flex items-center justify-center mx-auto mb-4 text-xl";
                if (type === 'success') {
                    iconEl.classList.add("bg-emerald-500/15", "text-emerald-400");
                    iconEl.innerHTML = '<i class="fa-solid fa-circle-check"></i>';
                } else if (type === 'danger') {
                    iconEl.classList.add("bg-rose-500/15", "text-rose-400");
                    iconEl.innerHTML = '<i class="fa-solid fa-triangle-exclamation"></i>';
                } else {
                    iconEl.classList.add("bg-sky-500/15", "text-sky-400");
                    iconEl.innerHTML = '<i class="fa-solid fa-circle-info"></i>';
                }
            }
            if (titleEl) titleEl.innerText = title;
            if (messageEl) messageEl.innerHTML = message;

            if (btnConfirm) {
                btnConfirm.onclick = function() {
                    overlay.classList.add("hidden");
                    overlay.classList.remove("flex");
                    if (onConfirm) onConfirm();
                };
            }
            if (btnCancel) {
                if (onCancel) {
                    btnCancel.classList.remove("hidden");
                    btnCancel.onclick = function() {
                        overlay.classList.add("hidden");
                        overlay.classList.remove("flex");
                        if (onCancel) onCancel();
                    };
                } else btnCancel.classList.add("hidden");
            }
            overlay.classList.remove("hidden");
            overlay.classList.add("flex");
        }

