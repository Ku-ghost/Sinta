        function processDeliveryConfirmationFlow(text, chatObj) {
            if (!chatObj.isAwaitingDeliveryConfirmation && !chatObj.isAwaitingDeliverySurvey) {
                return false; 
            }

            const cleanText = text.trim();
            const ant = STATE.antrean_antaran.find(a => a.id === chatObj.deliveryId);

            if (chatObj.isAwaitingDeliveryConfirmation) {
                if (cleanText === "1" || cleanText === "2") {
                    const isSesuai = cleanText === "1";
                    
                    if (ant) {
                        ant.status = isSesuai ? "Selesai_Sesuai" : "Selesai_Sesuai"; 
                        ant.completed_at = Date.now();
                        
                        const acceptedTime = ant.accepted_at ? ant.accepted_at : (Date.now() - (15 * 60 * 1000));
                        ant.duration = Math.round((Date.now() - acceptedTime) / (60 * 1000));
                        if (ant.duration <= 0) ant.duration = 15; 
                    }

                    chatObj.isAwaitingDeliveryConfirmation = false;
                    chatObj.isAwaitingDeliverySurvey = true;

                    const surveyTmpl = STATE.system_settings.TEMPLATE_ROBOT_SURVEY;
                    
                    chatObj.messages.push({ sender: 'user', text: isSesuai ? "1. Pesanan Obat di terima" : "2. Obat belum di terima", time: getCurrentWitaTime() });
                    chatObj.messages.push({ sender: 'bot', text: surveyTmpl.replace(/\n/g, "<br>"), time: getCurrentWitaTime() });
                    renderDeliveryTable();
                    return true;
                }
            } 
            else if (chatObj.isAwaitingDeliverySurvey) {
                const score = parseInt(cleanText);
                if (!isNaN(score) && score >= 1 && score <= 4) {
                    if (ant) {
                        ant.rating = (score === 1) ? 5 : (score === 2) ? 4 : (score === 3) ? 2 : 3;
                    }
                    chatObj.isAwaitingDeliverySurvey = false;
                    
                    STATE.kpi.satisfaction = Math.round((STATE.kpi.satisfaction + ((5 - score) * 25)) / 2);
                    renderKpiCards();

                    const closingText = `Terima kasih atas jawaban survei Anda. Konfirmasi Anda sangat berharga bagi kami dalam menjaga mutu pelayanan prima Instalasi Farmasi RSUD Sinjai. Semoga lekas sembuh!`;
                    chatObj.messages.push({ sender: 'user', text: `Memilih Opsi ${score}`, time: getCurrentWitaTime() });
                    chatObj.messages.push({ sender: 'bot', text: closingText, time: getCurrentWitaTime() });
                    
                    renderDeliveryTable();
                    return true;
                }
            }

            return false;
        }

