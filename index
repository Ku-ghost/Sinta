            result = result.replaceAll('[Waktu]', getWitaGreeting());
            result = result.replaceAll('[Nama_Lengkap]', patient ? patient.nama_lengkap : 'Pasien');
            result = result.replaceAll('[Link_Web_Pasien]', window.location.origin);
            result = result.replaceAll('[Tanggal_Tebus]', customData.tanggal_tebus || new Date().toLocaleDateString('id-ID'));
            result = result.replaceAll('[Estimasi]', customData.eta_estimation || '20');
