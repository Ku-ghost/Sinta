                    <textarea class="w-full bg-black/60 border border-white/10 rounded-lg p-3 font-mono text-[9.5px] text-cyan-300 outline-none focus:border-cyan-400" rows="8" readonly id="supabase-sql-textarea">
-- 1. Tabel Master Pasien
CREATE TABLE master_pasien (
    id VARCHAR(50) PRIMARY KEY,
    identity VARCHAR(50),
    nama_lengkap VARCHAR(150) NOT NULL,
    nomor_whatsapp VARCHAR(50) NOT NULL,
    usia INT,
    jenis_kelamin VARCHAR(20),
    kelurahan VARCHAR(100),
    alamat TEXT,
    gps TEXT,
    jenis_obat TEXT,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 2. Tabel Antrean Pengantaran (SYIFA)
CREATE TABLE antrean_antaran (
    id VARCHAR(50) PRIMARY KEY,
    patient_id VARCHAR(50) REFERENCES master_pasien(id) ON DELETE CASCADE,
    nama_lengkap VARCHAR(150),
    nomor_whatsapp VARCHAR(50),
    jenis_obat TEXT,
    kelurahan VARCHAR(100),
    alamat TEXT,
    gps TEXT,
    status VARCHAR(50) DEFAULT 'Pending',
    accepted_at BIGINT,
    completed_at BIGINT,
    duration INT,
    rating INT,
    eta_estimation VARCHAR(50),
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 3. Tabel Transaksi Resep (Edukasi SINTA & Notifikasi Jadwal)
CREATE TABLE transaksi_resep (
    id VARCHAR(50) PRIMARY KEY,
    pasien_id VARCHAR(50) REFERENCES master_pasien(id) ON DELETE CASCADE,
    obat_id VARCHAR(50),
    aturan_pakai TEXT,
    tanggal_tebus DATE,
    jam_konsumsi TIME,
    status_edukasi VARCHAR(100),
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 4. Tabel Log Pengaduan
CREATE TABLE log_pengaduan (
    id VARCHAR(50) PRIMARY KEY,
    pelapor VARCHAR(150),
    keluhan TEXT NOT NULL,
    waktu VARCHAR(50),
    sumber VARCHAR(50),
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);</textarea>
