        function simulateIncomingDirectChat() {
            let wa = document.getElementById("sim-sender-wa").value.trim();
            const text = document.getElementById("sim-msg-text").value.trim();
            if (!wa || !text) return showCustomDialog('danger', 'Kosong', 'Lengkapi nomor pengirim simulasi WA.');

            if (wa.startsWith('0')) wa = '62' + wa.slice(1);
            else if (wa.startsWith('8')) wa = '62' + wa;

            const patientMatch = STATE.master_pasien.find(p => p.nomor_whatsapp === wa);
            let chatObj = STATE.chats.find(c => c.patientWa === wa);
            if (!chatObj) {
                chatObj = { 
                    patientName: patientMatch ? patientMatch.nama_lengkap : `Anonim (+${wa})`, 
                    patientWa: wa, 
                    isBotActive: true, 
                    isSurveyPreEscalatePending: false,
                    isAwaitingDeliveryConfirmation: false,
                    isAwaitingDeliverySurvey: false,
                    deliveryId: null,
                    lastIncomingTime: Date.now(), 
                    messages: [] 
                };
                STATE.chats.unshift(chatObj);
            }

            chatObj.lastIncomingTime = Date.now();

            // Sesi intervensi flow delivery terlebih dahulu
            const isHandledByDeliveryFlow = processDeliveryConfirmationFlow(text, chatObj);
            
            if (!isHandledByDeliveryFlow) {
                chatObj.messages.push({ sender: 'user', text: text, time: getCurrentWitaTime() });
                if (chatObj.isBotActive) {
                    simulateDigitalResponse(text, chatObj);
                } else if (chatObj.isSurveyPreEscalatePending) {
                    simulateSurveyPreEscalateResponse(text, chatObj);
                }
            }

            document.getElementById("sim-msg-text").value = "";
            renderActiveChatsList();
            const findIdx = STATE.chats.findIndex(c => c.patientWa === wa);
            if (findIdx !== -1) selectChatSession(findIdx);
        }

        let alertedSessions = {}; 
        function monitorSlaAndAlerts() {
            if (STATE.portal !== 'internal') return;
            let renderNeeded = false;
            STATE.chats.forEach((c) => {
                if (c.isBotActive) return;
                const timeDiffMinutes = Math.floor((Date.now() - c.lastIncomingTime) / (60 * 1000));
                if (timeDiffMinutes >= STATE.system_settings.SLA_RESPONSE_MINUTES && !alertedSessions[c.patientWa]) {
                    alertedSessions[c.patientWa] = true; renderNeeded = true;
                }
            });
            if (renderNeeded) renderActiveChatsList();

            if (STATE.selectedChatSessionIndex !== null) {
                const activeSession = STATE.chats[STATE.selectedChatSessionIndex];
                const timerEl = document.getElementById("sla-countdown-timer");
                if (activeSession.isBotActive) {
                    const timerBox = document.getElementById("sla-countdown-box");
                    if (timerBox) timerBox.style.display = "none";
                }
                else {
                    const timerBox = document.getElementById("sla-countdown-box");
                    if (timerBox) timerBox.style.display = "inline-flex";
                    const elapsedMs = Date.now() - activeSession.lastIncomingTime;
                    const elapsedMin = Math.floor(elapsedMs / (60 * 1000));
                    const elapsedSec = Math.floor((elapsedMs % (60 * 1000)) / 1000);
                    if (timerEl) {
                        timerEl.innerText = `${elapsedMin}:${elapsedSec < 10 ? "0" + elapsedSec : elapsedSec}`;
                        if (elapsedMin >= STATE.system_settings.SLA_RESPONSE_MINUTES) timerEl.style.color = "var(--danger-color)";
                        else timerEl.style.color = "var(--success-color)";
                    }
                }
            }
        }

