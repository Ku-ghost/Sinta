        function isServiceOpen() {
            const now = new Date();
            const options = { timeZone: 'Asia/Makassar', hour: '2-digit', minute: '2-digit', hour12: false };
            const witaTimeStr = now.toLocaleTimeString('id-ID', options);
            const [curHour, curMin] = witaTimeStr.split(':').map(Number);
            
            const [openHour, openMin] = STATE.system_settings.OPEN_HOUR.split(':').map(Number);
            const [closeHour, closeMin] = STATE.system_settings.CLOSE_HOUR.split(':').map(Number);
            
            const curMinutes = curHour * 60 + curMin;
            const openMinutes = openHour * 60 + openMin;
            const closeMinutes = closeHour * 60 + closeMin;
            
            return curMinutes >= openMinutes && curMinutes < closeMinutes;
        }

