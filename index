        function recoverPinPositionFromSavedUrl(url, preserveUrl = null) {
            if (!url) return;
            try {
                const parts = url.split('&loc=');
                if (parts.length >= 3) {
                    const destinationLoc = decodeURIComponent(parts[2].split('&')[0]); 
                    const coords = destinationLoc.split(',');
                    if (coords.length === 2) {
                        const lat = parseFloat(coords[0]);
                        const lng = parseFloat(coords[1]);

                        if (!isNaN(lat) && !isNaN(lng)) {
                            if (STATE.leafletMap && STATE.leafletMarker) {
                                const newLatLng = new L.LatLng(lat, lng);
                                STATE.leafletMarker.setLatLng(newLatLng);
                                STATE.leafletMap.panTo(newLatLng);
                            }
                                
                            document.getElementById("p-reg-lat").value = lat.toFixed(6);
                            document.getElementById("p-reg-lng").value = lng.toFixed(6);
                            
                            const savedUrl = preserveUrl ? preserveUrl : url;
                            document.getElementById("p-reg-gps").value = savedUrl;
                            document.getElementById("p-reg-gps-display-input").value = savedUrl;
                        }
                    }
                }
            } catch (err) {
                console.warn("Gagal mendekode koordinat GPS:", err);
            }
        }

        function handlePastedCoordinates(urlValue) {
            const trimmedUrl = urlValue.trim();
            if (trimmedUrl.includes("&loc=")) {
                recoverPinPositionFromSavedUrl(trimmedUrl);
            } else if (trimmedUrl.includes("google.com/maps") || trimmedUrl.includes("goo.gl") || trimmedUrl.includes("@")) {
                try {
                    let lat, lng;
                    const atMatch = trimmedUrl.match(/@(-?\d+\.\d+),(-?\d+\.\d+)/);
                    const queryMatch = trimmedUrl.match(/q=(-?\d+\.\d+),(-?\d+\.\d+)/);

                    if (atMatch && atMatch.length >= 3) {
                        lat = parseFloat(atMatch[1]);
                        lng = parseFloat(atMatch[2]);
                    } else if (queryMatch && queryMatch.length >= 3) {
                        lat = parseFloat(queryMatch[1]);
                        lng = parseFloat(queryMatch[2]);
                    }

                    if (lat && lng) {
                        const simulatedOsmUrl = `https://routing.openstreetmap.de/?z=18&center=-5.128899%2C120.249444&loc=-5.128950%2C120.248655&loc=${lat}%2C${lng}&hl=en&alt=0&srv=0`;
                        recoverPinPositionFromSavedUrl(simulatedOsmUrl, trimmedUrl); 
                    } else {
                        document.getElementById("p-reg-gps").value = trimmedUrl;
                    }
                } catch(e) {
                    console.warn("Gagal parsing Google Maps URL:", e);
                    document.getElementById("p-reg-gps").value = trimmedUrl;
                }
            } else if (trimmedUrl !== "") {
                document.getElementById("p-reg-gps").value = trimmedUrl;
            }
        }

        function initializeRealMap() {
            try {
                const mapContainer = document.getElementById("p-reg-map-container");
                if (!mapContainer) return;
                
                if (typeof L === 'undefined') {
                    mapContainer.innerHTML = '<div class="h-full flex items-center justify-center text-rose-400 bg-slate-900/50 text-[10px] p-4 text-center">Modul Peta OSM (Leaflet) Gagal Dimuat secara Eksternal. Silakan isi alamat secara manual.</div>';
                    return;
                }

                STATE.leafletMap = L.map('p-reg-map-container').setView([STATE.hospitalCoord.lat, STATE.hospitalCoord.lng], 15);
                
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '&copy; OpenStreetMap contributors',
                    maxZoom: 19
                }).addTo(STATE.leafletMap);

                STATE.leafletMarker = L.marker([STATE.hospitalCoord.lat, STATE.hospitalCoord.lng], {
                    draggable: true
                }).addTo(STATE.leafletMap);

                STATE.leafletMarker.bindPopup("<b>Lokasi Antar</b><br>Geser pin ke titik koordinat rumah pasien.").openPopup();

                STATE.leafletMap.on('click', function(e) {
                    STATE.leafletMarker.setLatLng(e.latlng);
                    updateCoordinatesFromMarker(e.latlng);
                });

                STATE.leafletMarker.on('dragend', function(e) {
                    const position = STATE.leafletMarker.getLatLng();
                    updateCoordinatesFromMarker(position);
                });
                
                setTimeout(() => {
                    if (STATE.leafletMap) STATE.leafletMap.invalidateSize();
                }, 500);
            } catch(error) {
                console.error("Gagal memuat peta real:", error);
            }
        }
        
