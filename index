        function simulateDigitalResponse(userText, sessionObj) {
            setTimeout(() => {
                const query = userText.trim().toUpperCase();
                let reply = "";

                // 1. CEK JAM OPERASIONAL PELAYANAN BUKA/TUTUP
                if (!isServiceOpen()) {
                    reply = `Maaf, saat ini Layanan Asisten SINTA & SYIFA Apotek RSUD Sinjai telah TUTUP.\n\n🕒 *Jam Operasional Pelayanan:*\nSetiap Hari pukul ${STATE.system_settings.OPEN_HOUR} s/d ${STATE.system_settings.CLOSE_HOUR} WITA.\n\nPesan Anda telah disimpan secara aman. Petugas apoteker kami akan segera memproses sediaan resep Anda saat pelayanan dibuka kembali besok pagi. Terima kasih atas pengertian Anda.`;
                    sessionObj.messages.push({ sender: 'bot', text: reply.replace(/\n/g, "<br>"), time: getCurrentWitaTime() });
                    if (STATE.chats[STATE.selectedChatSessionIndex] === sessionObj) selectChatSession(STATE.selectedChatSessionIndex);
                    return;
                }

                const matchedPatient = STATE.master_pasien.find(p => p.nomor_whatsapp === sessionObj.patientWa);

                if (!matchedPatient) {
                    reply = parseMessageTemplate('TEMPLATE_SAPA_BELUM_DAFTAR', null);
                    sessionObj.messages.push({ sender: 'bot', text: reply.replace(/\n/g, "<br>"), time: getCurrentWitaTime() });
                    if (STATE.chats[STATE.selectedChatSessionIndex] === sessionObj) selectChatSession(STATE.selectedChatSessionIndex);
                    return;
                }

                const name = matchedPatient.nama_lengkap;
                const activeRecipes = STATE.transaksi_resep_pasien.filter(r => r.pasien_id === matchedPatient.id);

                const isQueryA = query === "A" || query.includes("INFO OBAT") || query.includes("ATURAN") || query.includes("CARA MINUM") || query.includes("DOSIS");
                const isQueryB = query === "B" || query.includes("STATUS") || query.includes("CEK STATUS") || query.includes("KURIR") || query.includes("POSISI") || query.includes("PENGIRIMAN");
                const isQueryC = query === "C" || query.includes("APOTEKER") || query.includes("TANYA") || query.includes("BANTUAN") || query.includes("MANUAL");
                const isQueryAduan = query.includes("KOMPLAIN") || query.includes("ADUAN") || query.includes("KECEWA") || query.includes("LAMBAT") || query.includes("KELUHAN");

                if (isQueryAduan) {
                    const complaintId = "ADUAN-" + Math.floor(1000 + Math.random() * 9000);
                    STATE.master_aduan.push({
                        id: complaintId,
                        pelapor: name,
                        keluhan: userText,
                        waktu: getCurrentWitaTime(),
                        sumber: 'WhatsApp Langsung'
                    });
                    STATE.kpi.complaints += 1;
                    renderKpiCards();

                    const targetLinesInfo = STATE.dinamik_pengaduan_wa.length > 0 
                        ? STATE.dinamik_pengaduan_wa.map(num => `+${num}`).join(', ') 
                        : "Nomor Duty Manager";

                    reply = `Mohon maaf atas ketidaknyamanan yang Ibu/Bapak ${name} alami.\n\nKeluhan Anda telah kami catat (ID: *${complaintId}*) dan saat ini sedang *diteruskan secara otomatis* ke Line Pengaduan kami:\n📞 ${targetLinesInfo}\n\nSistem SINTA dinonaktifkan sementara. Apoteker senior kami akan segera merespons Anda di obrolan ini.`;
                    sessionObj.isBotActive = false;
                }
                else if (isQueryA) {
                    if (activeRecipes.length > 0) {
                        let eduText = "";
                        activeRecipes.forEach(r => {
                            const d = STATE.master_obat.find(o => o.id === r.obat_id);
                            if (d) eduText += `💊 **Sediaan Obat:** ${d.nama_obat}\n📋 **Aturan Pakai:** ${r.aturan_pakai}\n💡 **Cara Penggunaan:** ${d.teks_edukasi}\n⚠️ **Efek Samping:** ${d.efek_samping_utama}\n\n`;
                        });
                        reply = parseMessageTemplate('TEMPLATE_EDUKASI_OBAT', matchedPatient, { daftar_obat: eduText });
                    } else if (matchedPatient.jenis_obat) {
                        reply = `Ibu/Bapak ${name}, berdasarkan catatan layanan Anda, berikut obat yang sedang dikonsumsi:\n\n**${matchedPatient.jenis_obat}**\n\nApakah informasi ini sudah jelas?\nKetik **[1]** jika Sudah Jelas, atau ketik **[2]** jika Belum Jelas/Butuh Apoteker.`;
                    } else {
                        reply = `Ibu/Bapak ${name}, resep Anda sedang diproses. Silakan ketik **[C]** jika Anda ingin bertanya langsung kepada Apoteker.`;
                    }
                } 
                else if (isQueryB) {
                    const antrean = STATE.antrean_antaran.find(a => a.nomor_whatsapp === matchedPatient.nomor_whatsapp && (a.status === "Pending" || a.status === "Diterima"));
                    
                    if (antrean) {
                        if (antrean.status === "Pending") {
                            reply = `Ibu/Bapak ${name}, permohonan pengantaran obat Anda saat ini *sedang menunggu persetujuan* dari Apoteker Jaga.\n\nKami akan segera memberi tahu jika obat sudah jalan.`;
                        } else if (antrean.status === "Diterima") {
                            reply = `Ibu/Bapak ${name}, paket obat Anda saat ini *sedang dalam perjalanan* ke lokasi alamat rumah.\n\nEstimasi tiba dalam waktu ${antrean.eta_estimation.replace(/\D/g, '')} menit.\n\nJika kurir sudah tiba, silakan konfirmasi dengan mengetik:\n👉 *1* jika Pesanan Obat Diterima\n👉 *2* jika Obat Belum Diterima`;
                            sessionObj.isAwaitingDeliveryConfirmation = true; 
                        }
                    } else {
                        reply = `Ibu/Bapak ${name}, saat ini tidak ada antrean pengantaran obat yang aktif atas nama Anda. Silakan isi form pendaftaran resep terlebih dahulu jika ingin menggunakan layanan SYIFA.`;
                    }
                }
                else if (isQueryC) {
                    reply = parseMessageTemplate('TEMPLATE_PREESCALATE_SURVEY', matchedPatient);
                    sessionObj.isBotActive = false;
                    sessionObj.isSurveyPreEscalatePending = true; 
                } 
                else if (query === "1" && sessionObj.messages.some(m => m.text.includes("Apakah petunjuk di atas sudah cukup jelas"))) {
                    reply = parseMessageTemplate('TEMPLATE_TUTUP_CUKUP', matchedPatient);
                }
                else if (query === "2" && sessionObj.messages.some(m => m.text.includes("Apakah petunjuk di atas sudah cukup jelas"))) {
                    reply = parseMessageTemplate('TEMPLATE_PREESCALATE_SURVEY', matchedPatient);
                    sessionObj.isBotActive = false;
                    sessionObj.isSurveyPreEscalatePending = true;
                }
                else {
                    reply = `Maaf, instruksi tidak dikenali.\n\nSilakan balas pesan ini dengan mengetik huruf pilihan:\n**[A]** Informasi Cara Minum Obat\n**[B]** Cek Status Pengiriman Obat\n**[C]** Hubungi Apoteker`;
                }

                sessionObj.messages.push({ sender: 'bot', text: reply.replace(/\n/g, "<br>"), time: getCurrentWitaTime() });
                if (STATE.chats[STATE.selectedChatSessionIndex] === sessionObj) selectChatSession(STATE.selectedChatSessionIndex);
            }, 1200);
        }

        function simulateSurveyPreEscalateResponse(userText, sessionObj) {
            setTimeout(() => {
                const query = userText.trim();
                const matchedPatient = STATE.master_pasien.find(p => p.nomor_whatsapp === sessionObj.patientWa);

                const score = parseInt(query);
                if (!isNaN(score) && score >= 1 && score <= 5) {
                    STATE.kpi.satisfaction = Math.round((STATE.kpi.satisfaction + (score * 20)) / 2);
                    renderKpiCards();
                }

                let reply = parseMessageTemplate('TEMPLATE_BUTUH_APOTEKER', matchedPatient);
                
                sessionObj.isBotActive = false;
                sessionObj.isSurveyPreEscalatePending = false;
                sessionObj.lastIncomingTime = Date.now(); 

                sessionObj.messages.push({ sender: 'bot', text: reply.replace(/\n/g, "<br>"), time: getCurrentWitaTime() });
                if (STATE.chats[STATE.selectedChatSessionIndex] === sessionObj) selectChatSession(STATE.selectedChatSessionIndex);
                renderActiveChatsList();
            }, 1000);
        }

        function triggerMedicationReminderSimulation(recipeId) {
            const recipe = STATE.transaksi_resep_pasien.find(r => r.id === recipeId);
            if (!recipe) return;
            const patient = STATE.master_pasien.find(p => p.id === recipe.pasien_id);
            const drug = STATE.master_obat.find(d => d.id === recipe.obat_id);
            if (!patient || !drug) return;

            let tmpl = STATE.system_settings.TEMPLATE_HUMANIS_PENGINGAT;
            tmpl = tmpl.replaceAll('[Nama_Lengkap]', patient.nama_lengkap);
            tmpl = tmpl.replaceAll('[Daftar_Obat]', `${drug.nama_obat} (${recipe.aturan_pakai})`);
            tmpl = tmpl.replaceAll('[Jam_Konsumsi]', recipe.jam_konsumsi || '08:00');

            let chatObj = STATE.chats.find(c => c.patientWa === patient.nomor_whatsapp);
            if (!chatObj) {
                chatObj = { 
                    patientName: patient.nama_lengkap, 
                    patientWa: patient.nomor_whatsapp, 
                    isBotActive: true, 
                    isSurveyPreEscalatePending: false,
                    isAwaitingDeliveryConfirmation: false,
                    isAwaitingDeliverySurvey: false,
                    deliveryId: null,
                    lastIncomingTime: Date.now(), 
                    messages: [] 
                };
                STATE.chats.unshift(chatObj);
            }

            chatObj.messages.push({ sender: 'bot', text: tmpl.replace(/\n/g, "<br>"), time: getCurrentWitaTime() });
            chatObj.lastIncomingTime = Date.now();
            
            renderActiveChatsList();
            showCustomDialog('success', 'Simulasi Pengingat Terkirim', `Pesan pengingat minum obat sopan (humanis) telah disimulasikan ke WhatsApp ${patient.nama_lengkap}.`);
        }

